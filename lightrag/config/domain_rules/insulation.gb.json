{
  "rules": [
    {
      "rule_id": "insulation.gb.power_frequency_split",
      "domain": "insulation",
      "kind": "split",
      "standard": "gb",
      "test_item": "工频耐受电压试验",
      "status": "active",
      "inputs": {
        "base_voltage_labels": [
          "额定短时工频耐受电压",
          "额定工频耐受电压"
        ],
        "fracture_voltage_labels": [
          "额定短时工频耐受电压(断口)",
          "额定工频耐受电压(断口)"
        ]
      },
      "single_output": {
        "test_item": "工频耐受电压试验",
        "parameter_overrides": {
          "试验部位": "相间、对地及断口",
          "试验次数": "9次"
        }
      },
      "split_output": [
        {
          "test_item": "工频耐受电压试验(断口)",
          "inherits_from": "工频耐受电压试验",
          "parameter_overrides": {
            "试验部位": "开关断口"
          }
        },
        {
          "test_item": "工频耐受电压试验(相间及对地)",
          "inherits_from": "工频耐受电压试验",
          "parameter_overrides": {
            "试验部位": "相间及对地"
          }
        }
      ]
    },
    {
